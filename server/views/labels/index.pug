extends ../layout

block content
  h1= t('labels')
  if currentUser
    a.btn.btn-primary.mb-3(href="/labels/new") #{t('createLabel')}
  table.table
    thead
      tr
        th ID
        th #{t('name')}
        th
    tbody
      each label in labels
        tr
          td= label.id
          td= label.name
          td
            if currentUser
              a.btn.btn-secondary.btn-sm(href=`/labels/${label.id}/edit`) #{t('edit')}
              form.d-inline(action=`/labels/${label.id}/delete` method="POST")
                button.btn.btn-danger.btn-sm(type="submit") #{t('delete')}